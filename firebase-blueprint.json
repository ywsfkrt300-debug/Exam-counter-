{
  "entities": {
    "Exam": {
      "title": "Exam",
      "description": "An exam with a target date for the countdown.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the exam." },
        "name": { "type": "string", "description": "Name of the exam (e.g., Ninth Grade, Baccalaureate)." },
        "targetDate": { "type": "string", "format": "date-time", "description": "The date and time of the exam." },
        "description": { "type": "string", "description": "Optional description of the exam." }
      },
      "required": ["id", "name", "targetDate"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Application-wide settings.",
      "type": "object",
      "properties": {
        "backgroundUrl": { "type": "string", "description": "URL of the background image." },
        "theme": { "type": "string", "enum": ["light", "dark", "glass"], "description": "The visual theme of the app." },
        "maintenanceMode": { "type": "boolean", "description": "Whether the site is in maintenance mode." },
        "overlayImageUrl": { "type": "string", "description": "URL of an image to display above the countdown." },
        "developerName": { "type": "string", "description": "Name of the developer." },
        "developerImageUrl": { "type": "string", "description": "URL of the developer's image." }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "A message or announcement to display on the website.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "message", "timestamp"]
    },
    "Presence": {
      "title": "Presence",
      "description": "Tracking active user sessions with location data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "ip": { "type": "string", "description": "User's IP address." },
        "governorate": { "type": "string", "description": "User's location/governorate." }
      },
      "required": ["id", "lastSeen"]
    },
    "Subject": {
      "title": "Subject",
      "description": "A study subject with multiple units.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "units": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "units"]
    },
    "UserProgress": {
      "title": "UserProgress",
      "description": "Tracking student progress on subjects.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "subjectId": { "type": "string" },
        "completedUnits": { "type": "array", "items": { "type": "string" } },
        "studyHours": { "type": "object", "description": "Map of unit name to hours." }
      },
      "required": ["sessionId", "subjectId"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "A study schedule image or file for students.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "imageUrl"]
    }
  },
  "firestore": {
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Collection of exams to count down to."
    },
    "/settings/config": {
      "schema": "Setting",
      "description": "Global application settings."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Announcements sent from the bot."
    },
    "/presence/{sessionId}": {
      "schema": "Presence",
      "description": "Active user sessions for counting."
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Study subjects added by the bot."
    },
    "/progress/{progressId}": {
      "schema": "UserProgress",
      "description": "Student progress tracking."
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Study schedules uploaded by the bot."
    }
  }
}
