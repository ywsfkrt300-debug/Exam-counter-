rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // WARNING: Security is reduced as Google Auth has been removed.
    // Anyone who knows the Firestore endpoint can now modify the data.
    // This was done per user request for a "password-only" flow.

    // Notifications
    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // Public Data
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if true;
    }
    match /exams/{examId} {
      allow read: if true;
      allow write: if true;
    }
    match /schedules/{scheduleId} {
      allow read: if true;
      allow write: if true;
    }
    match /settings/{configId} {
      allow read: if true;
      allow write: if true;
    }

    // User Data
    match /presence/{userId} {
      allow read, write: if true;
    }
    match /presence {
      allow list: if true;
    }
    match /progress/{userId} {
      allow read, write: if true;
    }
    match /progress {
      allow list: if true;
    }
    
    // Logs
    match /logs/{logId} {
      allow read, write: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
